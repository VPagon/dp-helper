# Copy this file to server/.env and fill in real values.
# server/.env is gitignored - never commit real credentials.
#
# Used by both the Express API (server/index.js) and the read-only
# Azure SQL MCP server (mcp-server/index.js).

PORT=5000

# --- dev (metadata) ---
DEV_METADATA_DB_SERVER=
DEV_METADATA_DB_NAME=
DEV_METADATA_DB_USER=
DEV_METADATA_DB_PASSWORD=

# --- prod (metadata) ---
PROD_METADATA_DB_SERVER=
PROD_METADATA_DB_NAME=
PROD_METADATA_DB_USER=
PROD_METADATA_DB_PASSWORD=

# --- deploy ---
DEPLOY_DB_SERVER=
DEPLOY_DB_NAME=
DEPLOY_DB_USER=
DEPLOY_DB_PASSWORD=
